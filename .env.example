# ===========================================
# landa-agent-service .env.example
# ===========================================
# Copy this file to .env and fill values. Never commit .env.
# See .planning/phases/01-setup-infra/CONTEXT.md for locked decisions.

# --- App ---
APP_ENV=dev                           # REQUIRED F1 — dev|staging|prod
APP_PUBLIC_URL=http://localhost:8000  # REQUIRED F1 — used as HTTP-Referer in OpenRouter calls
APP_VERSION=0.1.0                     # REQUIRED F1

# --- Postgres (Railway provides DATABASE_URL; we read POSTGRES_URL) ---
POSTGRES_URL=postgresql://user:pass@host:5432/landa_agent  # REQUIRED F1

# --- Redis ---
REDIS_URL=redis://default:pass@host:6379/0                 # REQUIRED F1

# --- OpenRouter (LLM gateway, no Anthropic/OpenAI direct) ---
OPENROUTER_API_KEY=sk-or-v1-<paste-here>                   # REQUIRED F1

# --- LLM model mapping (changeable without redeploy per CLAUDE.md rule) ---
LLM_MODEL_CONVERSATION=google/gemini-2.5-pro               # REQUIRED F1 — default conversation
LLM_MODEL_JUDGE=google/gemini-2.5-flash                    # REQUIRED F1 — temp=0
LLM_MODEL_INTENT=google/gemini-2.5-flash                   # REQUIRED F1
LLM_MODEL_SUMMARIZER=google/gemini-2.5-flash               # REQUIRED F1
LLM_FALLBACKS_CONVERSATION=anthropic/claude-3.5-sonnet,openai/gpt-4o-mini  # optional, comma-separated

# --- LangSmith (free tier per CONTEXT.md D-04) ---
LANGSMITH_API_KEY=ls-<paste-here>                          # REQUIRED F1
LANGSMITH_PROJECT=landa-agent-dev                          # REQUIRED F1 — landa-agent-{env}
LANGSMITH_TRACING=true                                     # REQUIRED F1 — enable auto-tracing

# --- Sentry ---
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<id>       # REQUIRED F1

# --- Meta WhatsApp Cloud API (F2) ---
WA_TOKEN=                                                  # F2+
WA_PHONE_ID=                                               # F2+
WA_WEBHOOK_SECRET=                                         # F2+ — HMAC X-Hub-Signature-256
WA_VERIFY_TOKEN=                                           # F2+ — Meta webhook verification

# --- SoftSeguros (F2) ---
SOFTSEGUROS_BASE_URL=https://app.softseguros.com/          # F2+
SOFTSEGUROS_USERNAME=                                      # F2+ — moves to db.tenant_configs later
SOFTSEGUROS_PASSWORD=                                      # F2+

# --- Chatwoot (F3) ---
CHATWOOT_URL=https://chat.landatech.org                    # F3+
CHATWOOT_API_KEY=                                          # F3+
CHATWOOT_ACCOUNT_ID=                                       # F3+
CHATWOOT_INBOX_ID=                                         # F3+

# --- lambda-proyect handoff (F6) ---
LAMBDA_PROYECT_BASE_URL=                                   # F6+
LAMBDA_PROYECT_INTERNAL_TOKEN=                             # F6+ — shared secret
