# ===========================================
# landa-agent-service .env.example
# ===========================================
# Copy this file to .env and fill values. Never commit .env.
# See .planning/phases/01-setup-infra/CONTEXT.md for locked decisions.

# --- App ---
APP_ENV=dev                           # REQUIRED F1 — dev|staging|prod
APP_PUBLIC_URL=http://localhost:8000  # REQUIRED F1 — used as HTTP-Referer in OpenRouter calls
APP_VERSION=0.1.0                     # REQUIRED F1

# --- Postgres (Railway provides DATABASE_URL; we read POSTGRES_URL) ---
POSTGRES_URL=postgresql://user:pass@host:5432/landa_agent  # REQUIRED F1

# --- Redis ---
REDIS_URL=redis://default:pass@host:6379/0                 # REQUIRED F1

# --- OpenRouter (LLM gateway, no Anthropic/OpenAI direct) ---
OPENROUTER_API_KEY=sk-or-v1-<paste-here>                   # REQUIRED F1

# --- LLM model mapping (changeable without redeploy per CLAUDE.md rule) ---
LLM_MODEL_CONVERSATION=google/gemini-2.5-pro               # REQUIRED F1 — default conversation
LLM_MODEL_JUDGE=google/gemini-2.5-flash                    # REQUIRED F1 — temp=0
LLM_MODEL_INTENT=google/gemini-2.5-flash                   # REQUIRED F1
LLM_MODEL_SUMMARIZER=google/gemini-2.5-flash               # REQUIRED F1
LLM_FALLBACKS_CONVERSATION=anthropic/claude-3.5-sonnet,openai/gpt-4o-mini  # optional, comma-separated

# --- LangSmith (free tier per CONTEXT.md D-04) ---
LANGSMITH_API_KEY=ls-<paste-here>                          # REQUIRED F1
LANGSMITH_PROJECT=landa-agent-dev                          # REQUIRED F1 — landa-agent-{env}
LANGSMITH_TRACING=true                                     # REQUIRED F1 — enable auto-tracing

# --- Sentry ---
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<id>       # REQUIRED F1

# --- Meta WhatsApp Cloud API (F2) ---
WA_TOKEN=                                                  # F2+
WA_PHONE_ID=                                               # F2+
WA_WEBHOOK_SECRET=                                         # F2+ — HMAC X-Hub-Signature-256
WA_VERIFY_TOKEN=                                           # F2+ — Meta webhook verification

# --- SoftSeguros (F2) ---
SOFTSEGUROS_BASE_URL=https://app.softseguros.com/          # F2+
SOFTSEGUROS_USERNAME=                                      # F2+ — moves to db.tenant_configs later
SOFTSEGUROS_PASSWORD=                                      # F2+

# === Chatwoot (Phase 3 — API Channel mirror) ===
# Self-hosted instance (Railway). The inbox here is the "API Channel"
# dedicated to bot mirror (separate from the WhatsApp native inbox of F4).
# Probe confirmed: CHATWOOT_INBOX_ID=2 has channel_type=Channel::Api (not Channel::Whatsapp).
CHATWOOT_URL=https://chat.landatech.org                    # F3+ — operator can override if domain changes
CHATWOOT_API_KEY=<user-level api_access_token from Chatwoot Profile>  # F3+ REQUIRED
CHATWOOT_ACCOUNT_ID=<int — visible in chat URL /app/accounts/N/...>   # F3+ REQUIRED
CHATWOOT_INBOX_ID=<int — id of the API Channel inbox created in 03-00>  # F3+ REQUIRED

# === Phase 4 — Payment / Cartera (D-06, D-22, D-23, D-15) ===
# Cartera allowlist — CSV of E.164 numbers authorized to send payment decisions.
# Example: CARTERA_PHONE_ALLOWLIST=+573001234567,+573019876543
CARTERA_PHONE_ALLOWLIST=                                   # F4+ REQUIRED — set before 04-05 deploys
# Railway volume mount path for comprobantes (D-01). Default /data/comprobantes.
PAYMENT_VOLUME_PATH=/data/comprobantes                     # F4+ optional — override if volume mounted elsewhere
# Meta template name for "no answer" follow-up (D-22). Must be pre-approved in Meta Business Suite.
META_TEMPLATE_NO_ANSWER_NAME=voice_no_answer_followup      # F4+ optional
# Lambda-proyect integration — shared internal token for /case/handoff/no_answer (D-23).
LAMBDA_PROYECT_BASE_URL=http://localhost:8001              # F4+ optional — override in production
LAMBDA_PROYECT_INTERNAL_TOKEN=                             # F4+ REQUIRED — shared secret with lambda-proyect
# Chatwoot outbound webhook HMAC secret (D-15).
# Set in Chatwoot admin → Settings → Integrations → Webhooks → Secret Token.
CHATWOOT_WEBHOOK_SECRET=                                   # F4+ REQUIRED — configure in Chatwoot admin

# Phase 5 — Audit log + rate limiting (SEC-01..SEC-06)
AUDIT_SINK_PATH=/data/comprobantes/audit
AUDIT_SINK_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PHONE_LIMIT=20
RATE_LIMIT_POLIZA_LIMIT=10
RATE_LIMIT_GLOBAL_LIMIT=500
RATE_LIMIT_WINDOW_S=60
